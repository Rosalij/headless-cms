// This is the TypeScript configuration file for the application.
// It defines the compiler options and settings for the TypeScript compiler, such as the target JavaScript version, module resolution, and paths for module imports. 
// It also specifies which files to include and exclude from the compilation process. 

{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
"paths": {
  "@/*": ["./src/*"]
}
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "tailwind.config.ts"  ],
  "exclude": ["node_modules"]
}
